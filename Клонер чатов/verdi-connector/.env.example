# Copy to .env before docker compose up
JWT_SECRET=change-me-use-long-random-string
SESSION_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Local without Docker (start-local.bat sets these automatically):
# DATABASE_URL=file:./dev.db
# USE_SYNC_OUTBOX=true

# Docker / production:
# DATABASE_URL=postgresql://verdi:verdi@postgres:5432/verdi_connector?schema=public
# REDIS_URL=redis://redis:6379

# Policy defaults
REPLY_ONLY=true
MAX_INITIATIONS_PER_HOUR=5
MAX_INITIATIONS_PER_DAY=20
MAX_REPLIES_PER_HOUR=60
MAX_DUPLICATE_TEMPLATE_RATIO=0.4
OUTBOUND_INBOUND_RISK_THRESHOLD=3.0
RISK_SCORE_INITIATION_BLOCK_THRESHOLD=70
SEND_DELAY_MIN_MS=800
SEND_DELAY_MAX_MS=3500

# Telegram command relay (optional)
COMMAND_RELAY_CHAT_ID=
COMMAND_RELAY_ALLOWED_USER_IDS=

# Seed operator (created on first boot)
SEED_OPERATOR_EMAIL=admin@verdi.local
SEED_OPERATOR_PASSWORD=admin123
SEED_OPERATOR_NAME=VERDI Admin
