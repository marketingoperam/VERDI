APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://shadowchat:shadowchat@db:5432/shadowchat
REDIS_URL=redis://redis:6379/0

LISTENER_API_ID=12345
LISTENER_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LISTENER_SESSION=listener_main

ADMIN_API_HOST=0.0.0.0
ADMIN_API_PORT=8000

PROFILE_SYNC_ENABLED=false
PROFILE_SYNC_INTERVAL_HOURS=24
DELETE_MODE=soft_delete
IGNORE_BOTS=true
IGNORE_SERVICE_MESSAGES=true
MAX_MEDIA_SIZE_MB=50
MESSAGE_FILTER_MODE=all
MIN_MESSAGE_LENGTH=0
SESSIONS_DIR=sessions
MEDIA_CACHE_DIR=media_cache

TG_PROXY=
TG_PROXY_TYPE=http
